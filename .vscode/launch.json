{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Uvicorn (FastAPI)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "env": {
                "FASTAPISTATIC": "1"
            },
            "args": [
                "core:app",
                "--host",
                "localhost",
                "--port",
                "9100"
            ],
            "console": "integratedTerminal"
        }
    ]
}
